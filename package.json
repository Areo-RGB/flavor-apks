{
  "name": "sprint-sync-tools",
  "private": true,
  "scripts": {
    "build:debug:apk": "cd android && gradlew.bat :app:assembleDebug",
    "build:debug:device-flavors": "cd android && gradlew.bat :app:assembleHostXiaomiDebug :app:assembleClientPixelDebug :app:assembleClientOneplusDebug :app:assembleClientHuaweiDebug :app:assembleClientXiaomiDebug",
    "build:release:apk": "cd android && gradlew.bat :app:assembleRelease",
    "rebuild:debug:devices": "npm run build:debug:apk && node scripts/install-debug-apk.mjs",
    "install:debug:device-flavors:adb": "node scripts/install-debug-device-flavors-adb.mjs",
    "rebuild:debug:device-flavors:adb": "npm run build:debug:device-flavors && npm run install:debug:device-flavors:adb",
    "install:release:devices": "node scripts/install-release-apk.mjs",
    "rebuild:release:devices": "npm run build:release:apk && node scripts/install-release-apk.mjs",
    "install:debug:devices:build": "npm run rebuild:debug:devices",
    "windows:install": "cd windows && npm install",
    "windows:dev": "cd windows && npm run dev",
    "windows:start:all": "cd windows && npm run start:all",
    "windows:dev:backend": "cd windows && npm run dev:backend",
    "windows:dev:ui": "cd windows && npm run dev:ui",
    "windows:build": "cd windows && npm run build",
    "windows:start": "cd windows && npm run start"
}}
