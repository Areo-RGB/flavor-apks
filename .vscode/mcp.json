{
  "servers": {
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}"
      ]
    },
 "intellij-index": {
      "url": "http://127.0.0.1:29170/index-mcp/streamable-http"
    },
    "intellij-debugger": {
      "url": "http://127.0.0.1:29190/debugger-mcp/streamable-http",
    },
    "context-mode": {
      "command": "context-mode"
    },
  "inputs": []
  }


}

